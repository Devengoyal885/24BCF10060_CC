class Solution {
public:
    bool containsNearbyDuplicate(vector<int>& nums, int k) {
        unordered_map<int,int> mpp;
        int n= nums.size();
        for(int i=0; i<n;i++){
        if(mpp.find(nums[i])!=mpp.end()){
        int diff=(i-mpp[nums[i]]);
        if(abs(diff)<=k){
            return true;
        }
        }
        mpp[nums[i]]=i;
        }
        return false;
    }
};
