class Solution {
public:
    vector<vector<int>> ans;

    void solve(int ind, vector<int>& subset, vector<int>& nums) {
        if (ind == nums.size()) {
            ans.push_back(subset);
            return;
        }
        subset.push_back(nums[ind]);
        solve(ind + 1, subset, nums);
        subset.pop_back();
        solve(ind + 1, subset, nums);
    }

    vector<vector<int>> subsets(vector<int>& nums) {
        vector<int> subset;
        solve(0, subset, nums);
        return ans;
    }
};
